# Makefile template — generated by python-blueprint setup skill
#
# TEMPLATE VARIABLES:
#   ${PACKAGE_MANAGER}      — e.g., "uv"
#   ${PACKAGE_MANAGER_RUN}  — e.g., "uv run"
#   ${INSTALL_COMMAND}      — e.g., "uv sync"

.PHONY: setup build test lint format clean help

help: ## Show this help
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "  %-10s %s\n", $$1, $$2}'

setup: ## Install dependencies and pre-commit hooks
	${INSTALL_COMMAND}
	${PACKAGE_MANAGER_RUN} pre-commit install

build: ## Build the package
	${PACKAGE_MANAGER} build

test: ## Run tests with coverage
	${PACKAGE_MANAGER_RUN} pytest --cov

lint: ## Run linter and format check
	${PACKAGE_MANAGER_RUN} ruff check .
	${PACKAGE_MANAGER_RUN} ruff format --check .

format: ## Auto-format code
	${PACKAGE_MANAGER_RUN} ruff format .
	${PACKAGE_MANAGER_RUN} ruff check --fix .

clean: ## Remove build artifacts
	rm -rf dist/ build/ *.egg-info/
	find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
	find . -type f -name "*.pyc" -delete
