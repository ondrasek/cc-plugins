# Makefile for Neovim Lua plugin development
# Generated by nvim-lua-blueprint setup skill
#
# THIS IS AN ANNOTATED EXAMPLE. The setup skill should adjust paths and
# commands based on the project's structure and detected test framework.
#
# TEMPLATE VARIABLES:
#   ${SOURCE_DIR}           — main source directory (e.g., "lua/")
#   ${TEST_DIR}             — test directory (e.g., "tests/")
#   ${TEST_COMMAND}         — test invocation command
#   ${COMPLEXITY_THRESHOLD} — max cyclomatic complexity (e.g., 10)

.PHONY: test lint format check clean help

## Run tests
test:
	${TEST_COMMAND}

## Run linter (selene)
lint:
	selene ${SOURCE_DIR}

## Format code (stylua)
format:
	stylua ${SOURCE_DIR}

## Run all checks (lint + format check + complexity + test)
check: lint
	stylua --check ${SOURCE_DIR}
	lizard ${SOURCE_DIR} --CCN ${COMPLEXITY_THRESHOLD} --warnings_only
	$(MAKE) test

## Clean generated files
clean:
	rm -f luacov.stats.out luacov.report.out

## Show this help
help:
	@echo "Available targets:"
	@echo "  test    — Run tests"
	@echo "  lint    — Run selene linter"
	@echo "  format  — Format with stylua"
	@echo "  check   — Run all checks (lint, format, complexity, test)"
	@echo "  clean   — Remove generated files"
	@echo "  help    — Show this help"
