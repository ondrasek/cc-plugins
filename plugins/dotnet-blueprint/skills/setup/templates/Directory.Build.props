<!-- Directory.Build.props
     Centralized MSBuild properties for quality methodology.
     Generated by dotnet-blueprint setup skill.

     THIS IS AN ANNOTATED EXAMPLE. The setup skill should merge these
     properties into existing Directory.Build.props if one exists.

     TEMPLATE VARIABLES:
       ${DOTNET_VERSION}  — target framework (e.g., "net9.0")
       ${LANGVERSION}     — C# language version (e.g., "13")
-->
<Project>

  <PropertyGroup>
    <!-- Type Safety: Enable nullable reference types -->
    <Nullable>enable</Nullable>

    <!-- Code Analysis: Use latest recommended rules -->
    <AnalysisLevel>latest-Recommended</AnalysisLevel>

    <!-- Strict: Treat analyzer warnings as errors in CI -->
    <!-- Set via -warnaserror flag in CI, not globally here -->
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
  </PropertyGroup>

  <!-- Analyzer packages — added to all projects in the solution -->
  <ItemGroup>
    <!-- Style enforcement and code quality -->
    <!-- <PackageReference Include="StyleCop.Analyzers" Version="1.2.0-beta.*" PrivateAssets="all" /> -->
    <!-- <PackageReference Include="Roslynator.Analyzers" Version="4.*" PrivateAssets="all" /> -->
    <!-- <PackageReference Include="Meziantou.Analyzer" Version="2.*" PrivateAssets="all" /> -->

    <!-- Security analyzers -->
    <!-- <PackageReference Include="Microsoft.CodeAnalysis.BannedApiAnalyzers" Version="3.*" PrivateAssets="all" /> -->
    <!-- <PackageReference Include="SecurityCodeScan.VS2019" Version="5.*" PrivateAssets="all" /> -->
  </ItemGroup>

</Project>
